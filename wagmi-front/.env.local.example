# ============================================================
# TokenBank 前端环境变量 - 多链配置版
# ============================================================
# 用法：将本文件复制为 .env.local 并按需修改地址
#   cp .env.local.example .env.local
#
# 所有 NEXT_PUBLIC_ 前缀的变量会暴露给浏览器端，不要放私钥。
# 修改后需重启 `npm run dev` 才会生效。
# ============================================================


# ----- 必填：Reown AppKit -----

# Reown Cloud Project ID，用于 AppKit 钱包登录
# 从 https://cloud.reown.com/ 创建项目后获取
NEXT_PUBLIC_REOWN_PROJECT_ID=


# ============================================================
# Local 链配置 (foundry/anvil, chainId: 31337)
# ============================================================

# MyERC20 代币合约地址
NEXT_PUBLIC_TOKEN_ADDRESS_LOCAL=0x51a1ceb83b83f1985a81c295d1ff28afef186e02

# TokenBank 合约地址
NEXT_PUBLIC_TOKENBANK_ADDRESS_LOCAL=0x36b58f5c1969b7b6591d752ea6f5486d069010ab

# NFTMarket 合约地址
NEXT_PUBLIC_NFT_MARKET_ADDRESS_LOCAL=0x8198f5d8f8cffe8f9c413d98a0a55aeb8ab9fbb7

# SimpleNft 合约地址（用于 NFTMarket 测试的 ERC721）
NEXT_PUBLIC_SIMPLE_NFT_ADDRESS_LOCAL=0x0355b7b8cb128fa5692729ab3aaa199c1753f726


# ============================================================
# Sepolia 测试网配置 (chainId: 11155111)
# ============================================================

# MyERC20 代币合约地址
NEXT_PUBLIC_TOKEN_ADDRESS_SEPOLIA=

# TokenBank 合约地址
NEXT_PUBLIC_TOKENBANK_ADDRESS_SEPOLIA=

# NFTMarket 合约地址
NEXT_PUBLIC_NFT_MARKET_ADDRESS_SEPOLIA=

# SimpleNft 合约地址
NEXT_PUBLIC_SIMPLE_NFT_ADDRESS_SEPOLIA=


# ============================================================
# Polygon 主网配置 (chainId: 137)
# ============================================================

# MyERC20 代币合约地址
NEXT_PUBLIC_TOKEN_ADDRESS_POLYGON=

# TokenBank 合约地址
NEXT_PUBLIC_TOKENBANK_ADDRESS_POLYGON=

# NFTMarket 合约地址
NEXT_PUBLIC_NFT_MARKET_ADDRESS_POLYGON=

# SimpleNft 合约地址
NEXT_PUBLIC_SIMPLE_NFT_ADDRESS_POLYGON=


# ============================================================
# Optimism 主网配置 (chainId: 10)
# ============================================================

# MyERC20 代币合约地址
NEXT_PUBLIC_TOKEN_ADDRESS_OPTIMISM=

# TokenBank 合约地址
NEXT_PUBLIC_TOKENBANK_ADDRESS_OPTIMISM=

# NFTMarket 合约地址
NEXT_PUBLIC_NFT_MARKET_ADDRESS_OPTIMISM=

# SimpleNft 合约地址
NEXT_PUBLIC_SIMPLE_NFT_ADDRESS_OPTIMISM=


# ============================================================
# 重要说明
# ============================================================
# 1. TokenBank 构造时传入的 token 地址必须与对应链的 NEXT_PUBLIC_TOKEN_ADDRESS_XXX 一致
# 2. NFTMarket 构造时传入的 paymentToken 必须与对应链的 NEXT_PUBLIC_TOKEN_ADDRESS_XXX 一致
# 3. 重新部署合约后，请更新对应链的合约地址
# 4. RPC URL 已通过 appkit 配置，如需自定义请修改 src/lib/appkit.ts
# 5. 切换链后，应用会自动加载对应链的合约地址