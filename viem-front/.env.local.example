# ============================================================
# TokenBank 前端环境变量
# ============================================================
# 用法：将本文件复制为 .env.local 并按需修改地址
#   cp .env.local.example .env.local
#
# 所有 NEXT_PUBLIC_ 前缀的变量会暴露给浏览器端，不要放私钥。
# 修改后需重启 `npm run dev` 才会生效。
# ============================================================


# ----- 必填：合约地址 -----

# MyERC20 代币合约地址
NEXT_PUBLIC_TOKEN_ADDRESS=0xE6E340D132b5f46d1e472DebcD681B2aBc16e57E

# TokenBank 合约地址
NEXT_PUBLIC_TOKENBANK_ADDRESS=0xc5a5C42992dECbae36851359345FE25997F5C42d

# ⚠️ 重要：TokenBank 构造时传入的 token 地址必须与上面的
# NEXT_PUBLIC_TOKEN_ADDRESS 一致，否则存款会失败。
# 如果重新部署了合约，请同时更新这两个地址。
# 可调用 TokenBank.token() 验证底层代币地址是否匹配。


# ----- NFTMarket 相关 -----

# NFTMarket 合约地址
NEXT_PUBLIC_NFT_MARKET_ADDRESS=

# SimpleNft 合约地址（用于 NFTMarket 测试的 ERC721，铸造脚本与前端共用）
NEXT_PUBLIC_SIMPLE_NFT_ADDRESS=

# ⚠️ 重要：NFTMarket 构造时传入的 paymentToken 必须与上面的
# NEXT_PUBLIC_TOKEN_ADDRESS 一致，否则购买时转账会失败。


# ----- 可选：链与 RPC 配置 -----

# RPC 端点（默认 http://127.0.0.1:8545，即本地 anvil）
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# 链 ID（默认 31337 = anvil/foundry）
# 当链 ID 为 31337 时自动使用 viem 内置的 foundry 链定义；
# 否则用 NEXT_PUBLIC_CHAIN_NAME 自建链定义。
# NEXT_PUBLIC_CHAIN_ID=31337

# 链名称（仅当 NEXT_PUBLIC_CHAIN_ID 不为 31337 时生效）
# NEXT_PUBLIC_CHAIN_NAME=Custom Chain
