# ====== TokenBank 部署配置示例 ======
# 复制本文件为 .env 并填入实际值: cp .env.example .env

# 部署用私钥（请勿提交到版本控制）
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# TokenBank 构造函数参数：底层 ERC20 代币合约地址
TOKEN_ADDRESS=0xYOUR_ERC20_TOKEN_ADDRESS

# 目标链的 RPC URL
RPC_URL=http://127.0.0.1:8545

# Sepolia RPC URL（被 foundry.toml 的 [rpc_endpoints] sepolia 引用）
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<YOUR_API_KEY>

# MyERC20 构造函数参数：代币名称与符号
# 留空时会使用脚本中的默认值 "MyToken" / "MTK"
TOKEN_NAME=MyToken
TOKEN_SYMBOL=MTK

# ====== NFTMarket 部署 ======
# NFTMarket 构造函数参数：支付代币地址（复用上面的 TOKEN_ADDRESS）
# 部署命令：
#   forge script script/NFTMarket.s.sol --rpc-url local --broadcast
# 部署后将输出的地址填入 viem-front/.env.local 的 NEXT_PUBLIC_NFT_MARKET_ADDRESS
